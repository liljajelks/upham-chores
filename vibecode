            </div>
          </div>

          <div style={{background:"#FFF",border:`1px solid ${C.tanLt}`,borderRadius:10,padding:18,marginBottom:14,boxShadow:"0 2px 6px rgba(0,0,0,0.04)"}}>
            <div style={{...sh.playfair,fontSize:15,fontWeight:700,color:C.wood,marginBottom:12}}>🧹 Chore List</div>
            {chores.map(c=>(
              <div key={c.id} style={{display:"flex",alignItems:"center",gap:10,padding:"8px 0",borderBottom:`1px solid ${C.creamLt}`}}>
                <span style={{fontSize:20}}>{c.emoji}</span>
                <span style={{flex:1,fontSize:14,color:C.wood}}>{c.name}</span>
                <button style={{background:"none",border:"none",cursor:"pointer",color:C.red,fontSize:18,padding:"2px 6px"}} onClick={()=>saveChores(chores.filter(x=>x.id!==c.id))}>×</button>
              </div>
            ))}
            <div style={{display:"flex",gap:8,marginTop:14}}>
              <input style={{width:46,flex:"none",padding:"9px 6px",border:`1px solid ${C.tanLt}`,borderRadius:7,textAlign:"center",fontSize:18,background:C.creamLt,outline:"none"}} value={newEmoji} onChange={e=>setNE(e.target.value)} maxLength={2}/>
              <input style={{flex:1,padding:"9px 12px",border:`1px solid ${C.tanLt}`,borderRadius:7,...sh.lora,fontSize:14,background:C.creamLt,color:C.wood,outline:"none"}} placeholder="Add a chore…" value={newChore} onChange={e=>setNC(e.target.value)} onKeyDown={e=>{if(e.key==="Enter"&&newChore.trim()){saveChores([...chores,{id:`c${Date.now()}`,name:newChore.trim(),emoji:newEmoji||"🏠"}]);setNC("");setNE("🏠");}}}/>
              <button style={{padding:"9px 14px",background:C.wood,color:C.cream,border:"none",borderRadius:7,...sh.lora,fontSize:13,cursor:"pointer",fontWeight:600}} onClick={()=>{if(newChore.trim()){saveChores([...chores,{id:`c${Date.now()}`,name:newChore.trim(),emoji:newEmoji||"🏠"}]);setNC("");setNE("🏠");}}}>Add</button>
            </div>
          </div>

          <div style={{background:"#FFF",border:`1px solid ${C.tanLt}`,borderRadius:10,padding:18,marginBottom:14,boxShadow:"0 2px 6px rgba(0,0,0,0.04)"}}>
            <div style={{...sh.playfair,fontSize:15,fontWeight:700,color:C.wood,marginBottom:10}}>🔄 Rotation</div>
            <div style={{background:C.tanLt,borderRadius:8,padding:"12px 14px",fontSize:13,color:C.woodMid,lineHeight:1.8,border:`1px solid ${C.tan}`}}>
              Assignments rotate every <strong>Monday at midnight</strong>.<br/>
              With {people.length} housemates, each person repeats every {people.length} weeks.<br/>
              Rotation week: <strong>{(WEEK.weekOffset % Math.max(people.length,1))+1} of {people.length}</strong>
            </div>
          </div>

          <div style={{background:"#FFF",border:"1px solid #F0D0D0",borderRadius:10,padding:18,boxShadow:"0 2px 6px rgba(0,0,0,0.04)"}}>
            <div style={{...sh.playfair,fontSize:15,fontWeight:700,color:C.red,marginBottom:10}}>⚠️ Danger Zone</div>
            <button style={{padding:"9px 14px",background:C.red,color:"white",border:"none",borderRadius:7,...sh.lora,fontSize:13,cursor:"pointer",fontWeight:600}} onClick={()=>{if(window.confirm("Clear ALL history? This can't be undone."))saveComp({});}}>
              Clear All History
            </button>
          </div>
        </>}

      </div>
    </div>
  );
}
