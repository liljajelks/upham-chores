// ─── Week Helpers ───────────────────────────────────────────────────
function getWeekData(date = new Date()) {
  const d = new Date(date);
  const day = d.getDay();
  const diff = day === 0 ? -6 : 1 - day;
  const monday = new Date(d);
  monday.setDate(d.getDate() + diff);
  monday.setHours(0, 0, 0, 0);
  const sunday = new Date(monday);
  sunday.setDate(monday.getDate() + 6);
  const epoch = new Date("2024-01-01T00:00:00");
  const weekOffset = Math.floor((monday - epoch) / (7 * 24 * 60 * 60 * 1000));
  const key = monday.toISOString().split("T")[0];
  return { key, monday, sunday, weekOffset };
}

const WEEK = getWeekData();
const fmtShort = (d) => new Date(d).toLocaleDateString("en-US", { month: "short", day: "numeric" });
const fmtTime  = (iso) => new Date(iso).toLocaleDateString("en-US", { month: "short", day: "numeric", hour: "numeric", minute: "2-digit", hour12: true });
const fmtWeekLabel = (key) => {
  const m = new Date(key + "T00:00:00");
  const s = new Date(m); s.setDate(m.getDate() + 6);
  return `${fmtShort(m)} – ${fmtShort(s)}`;
};

