// ─── Comic Explosion Component ──────────────────────────────────────
function ComicBoom({ boom, onDone }) {
  const [phase, setPhase] = useState("enter"); // enter → hold → exit

  useEffect(() => {
    const t1 = setTimeout(() => setPhase("hold"), 50);
    const t2 = setTimeout(() => setPhase("exit"), 900);
    const t3 = setTimeout(() => onDone(), 1300);
    return () => { clearTimeout(t1); clearTimeout(t2); clearTimeout(t3); };
  }, []);

  const scale   = phase === "enter" ? 0.2 : phase === "hold" ? 1.08 : 1.5;
  const opacity = phase === "exit"  ? 0   : 1;
  const rotate  = phase === "enter" ? -15 : phase === "hold" ? 3 : 8;

  return (
    <div style={{
      position:"fixed", inset:0, zIndex:9999,
      display:"flex", alignItems:"center", justifyContent:"center",
      pointerEvents:"none",
    }}>
      {/* Halftone radial burst backdrop */}
      <div style={{
        position:"absolute", inset:0,
        background: phase === "exit"
          ? "transparent"
          : `radial-gradient(ellipse 55% 55% at 50% 50%, ${boom.bg}CC 0%, ${boom.bg}44 50%, transparent 75%)`,
        opacity, transition:"opacity 0.3s ease",
      }}/>

      {/* Starburst SVG behind word */}
      <div style={{
        position:"absolute",
        transform:`scale(${scale}) rotate(${rotate}deg)`,
        transition: phase==="enter"
          ? "transform 0.12s cubic-bezier(0.34,1.8,0.64,1)"
          : phase==="exit"
          ? "transform 0.4s ease-in, opacity 0.4s ease-in"
          : "transform 0.08s ease-out",
        opacity, width:300, height:300,
        display:"flex", alignItems:"center", justifyContent:"center",
      }}>
        {/* Starburst */}
        <svg width="300" height="300" style={{position:"absolute"}}>
          {[...Array(16)].map((_,i) => {
            const angle = (i / 16) * 360;
            const x1 = 150 + 60  * Math.cos(angle * Math.PI / 180);
            const y1 = 150 + 60  * Math.sin(angle * Math.PI / 180);
            const x2 = 150 + 140 * Math.cos(angle * Math.PI / 180);
            const y2 = 150 + 140 * Math.sin(angle * Math.PI / 180);
            const midAngle = angle + (360 / 32);
            const mx = 150 + 110 * Math.cos(midAngle * Math.PI / 180);
            const my = 150 + 110 * Math.sin(midAngle * Math.PI / 180);
            return (
              <polygon key={i}
                points={`${x1},${y1} ${mx},${my} ${x2},${y2}`}
                fill={boom.bg}
                stroke={boom.shadow}
                strokeWidth="1.5"
              />
            );
          })}
          <circle cx="150" cy="150" r="62" fill={boom.bg} stroke={boom.shadow} strokeWidth="3"/>
        </svg>

        {/* The word */}
        <div style={{
          position:"relative", zIndex:2,
          fontFamily:"'Bangers',Impact,'Arial Black',sans-serif",
          fontSize: boom.word.length > 5 ? "52px" : "68px",
          color: boom.color,
          letterSpacing:"4px",
          textShadow:`
            3px  3px 0 ${boom.shadow},
           -1px -1px 0 ${boom.shadow},
            1px -1px 0 ${boom.shadow},
           -1px  1px 0 ${boom.shadow},
            5px  5px 0 rgba(0,0,0,0.25)
          `,
          WebkitTextStroke:`2px ${boom.shadow}`,
          lineHeight:1,
          userSelect:"none",
        }}>
          {boom.word}
        </div>

        {/* Speed lines */}
        {[...Array(8)].map((_,i) => {
          const angle = (i / 8) * 360;
          return (
            <div key={i} style={{
              position:"absolute",
              width: 2, height: phase==="hold" ? 55 : 15,
              background:`linear-gradient(transparent, ${boom.bg})`,
              transformOrigin:"50% 0%",
              top:"50%", left:"50%",
              marginLeft:-1, marginTop:-1,
              transform:`rotate(${angle}deg) translateY(-155px)`,
              transition:"height 0.15s ease",
              borderRadius:2,
            }}/>
          );
        })}
      </div>
    </div>
  );
}

